{
  "name": "@falcondev-oss/configs",
  "type": "module",
  "version": "6.0.3",
  "license": "MIT",
  "repository": "github:falcondev-oss/configs",
  "keywords": [
    "eslint-config",
    "prettier-config",
    "commitlint-config"
  ],
  "exports": {
    "./prettier": {
      "default": "./src/prettier/index.js"
    },
    "./eslint": {
      "types": "./src/eslint/index.d.ts",
      "default": "./src/eslint/index.js"
    },
    "./commitlint": {
      "default": "./src/commitlint/index.js"
    }
  },
  "files": [
    "./src"
  ],
  "engines": {
    "node": "24",
    "pnpm": "11"
  },
  "scripts": {
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write ."
  },
  "peerDependencies": {
    "eslint": ">=10.6.0",
    "prettier": ">=3.9.3"
  },
  "dependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/types": "^21.1.0",
    "@eslint-react/eslint-plugin": "^5.10.0",
    "@eslint/compat": "^2.1.0",
    "@nuxt/eslint-config": "^1.16.0",
    "@shopify/eslint-plugin": "^50.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-unicorn": "^69.0.0",
    "local-pkg": "^1.2.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@types/eslint": "^9.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^24.13.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.3",
    "typescript": "^6.0.3"
  },
  "browserslist": [
    "> 0.5% in DE, last 3 versions, Firefox ESR, not dead and fully supports es6-module",
    "maintained node versions"
  ],
  "changelogithub": {
    "extends": "gh:falcondev-it/configs/changelogithub"
  }
}
